// Snippet to merge into your root Firestore rules (inside `match /databases/{database}/documents { ... }`).
//
// Collection: testimonialVideos
// Fields: title, storagePath, downloadUrl, fileName, sizeBytes, mimeType, createdAt, active

match /testimonialVideos/{videoId} {
  allow read: if request.auth != null;
  allow create, update, delete: if request.auth != null;
}

// Firebase Storage (separate rules file): allow read on testimonial-videos/* for authenticated users;
// write for staff accounts used by the master portal.
